{
    "type": "object",
    "required": ["app", "database"],
    "properties": {
        "app": {
            "type": "object",
            "required": ["name"],
            "properties": {
                "name": { "type": "string" },
                "debug": { "type": "boolean" }
            }
        },
        "database": {
            "type": "object",
            "required": ["host", "port"],
            "properties": {
                "host": { "type": "string" },
                "port": { "type": "number", "minimum": 1, "maximum": 65535 }
            }
        }
    }
}
